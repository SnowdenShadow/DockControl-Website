# Dépendances et artefacts de build (réinstallés/régénérés dans l'image)
node_modules
.next
out
build

# Méta / outillage local
.git
.gitignore
.dockerignore
Dockerfile
docker-compose.yml
.design-ref
README.md

# Env (ne jamais copier dans l'image — l'URL passe par un build-arg).
# Next.js auto-charge .env, .env.production et .env.development au build :
# on les exclut tous pour éviter qu'un fichier traînant ne fuite dans l'image.
.env
.env.*

# Logs et divers
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.tsbuildinfo
.DS_Store
.vscode
.idea
