# URL publique du site, sans slash final.
# Utilisée pour les balises canoniques, OpenGraph/Twitter, le sitemap.xml et
# le robots.txt. Variable NEXT_PUBLIC_* : elle est inlinée au BUILD, pas au
# runtime — un changement nécessite un rebuild.
#
# En local, copiez ce fichier en .env.local et ajustez si besoin.
# En Docker, passez-la en build-arg (voir Dockerfile / docker-compose.yml).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Port d'écoute du conteneur côté hôte (docker-compose).
# PORT=3000
